# Embedding Agent Configuration
# Copy to .env and customize

# Weaviate Connection (via Tailscale)
WEAVIATE_URL=http://devnode:8080
WEAVIATE_API_KEY=

# Embedding Model Configuration
# Options: bge-small, bge-base, all-MiniLM-L6-v2
EMBEDDING_MODEL=bge-small
EMBEDDING_BATCH_SIZE=32

# LM Studio fallback (optional)
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_EMBEDDING_MODEL=

# File Watcher Configuration
WATCH_PATHS=/Users/alex/Projects
WATCH_RECURSIVE=true

# File patterns to include (comma-separated)
INCLUDE_PATTERNS=*.ts,*.tsx,*.py,*.md,*.txt,*.rtf,*.csv,*.html,*.css,*.js,*.yml,*.yaml,*.json,*.jsonc

# Patterns to exclude (comma-separated)
EXCLUDE_PATTERNS=node_modules,__pycache__,.git,.next,dist,build,.venv,venv

# Processing Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=10

# Sync State
STATE_DB_PATH=./state.db

# Logging
LOG_LEVEL=INFO
