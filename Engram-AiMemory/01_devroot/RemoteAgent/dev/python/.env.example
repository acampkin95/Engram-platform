# Weaviate Connection (devnode via Tailscale)
WEAVIATE_HOST=devnode
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# LM Studio
LMSTUDIO_HOST=localhost
LMSTUDIO_PORT=1234
EMBEDDING_MODEL=nomic-embed-text-v1.5

# Watch Directories (comma-separated)
WATCH_DIRS=/Users/alex/Projects

# File Patterns
INCLUDE_EXTENSIONS=.ts,.tsx,.py,.md,.txt,.rtf,.csv,.html,.css,.js,.yaml,.yml,.json,.jsonc

# Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
BATCH_SIZE=100

# State
STATE_DB_PATH=./state/file_hashes.db

# API Server
API_HOST=127.0.0.1
API_PORT=8765
