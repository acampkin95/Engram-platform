# =============================================================================
# AI Memory System — Production Environment Configuration
# =============================================================================
# Copy to .env and fill in values BEFORE running deploy-server.sh.
# The deploy script auto-generates secrets marked [AUTO-GENERATED].
#
# Networking: Tailscale VPN only (no public internet exposure).
# TLS: Handled by Tailscale/WireGuard — HTTP only to Traefik.
# Inference: Ollama (CPU-only, nomic embeddings + LFM 2.5 LLM).
# =============================================================================

# =============================================================================
# TRAEFIK / NETWORKING
# =============================================================================
# Your machine's Tailscale DNS hostname (from `tailscale status`)
# Services route as: api.memory.internal, dashboard.memory.internal, etc.
# See docker/traefik/dynamic.yml to customize hostname rules.
TRAEFIK_DOMAIN=acdev-devnode.tail1234.ts.net

# =============================================================================
# WEAVIATE CONFIGURATION
# =============================================================================
# Internal URL (container-to-container via memory-network)
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_GRPC_URL=http://weaviate:50051

# API key for Weaviate (set if AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED=false)
# [AUTO-GENERATED by deploy-server.sh]
WEAVIATE_API_KEY=change-me-or-auto-generated

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Internal URL (container-to-container via memory-network)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# =============================================================================
# OLLAMA CONFIGURATION
# =============================================================================
# Internal URL to Ollama container (container-to-container)
OLLAMA_HOST=http://ollama:11434

# =============================================================================
# EMBEDDING CONFIGURATION (Ollama / nomic-embed-text)
# =============================================================================
# Use Ollama for embeddings — no OpenAI required for core functionality.
# nomic-embed-text-v1.5 produces 768-dim embeddings (vs 1536 for OpenAI).
EMBEDDING_PROVIDER=nomic
EMBEDDING_MODEL=nomic-embed-text:v1.5
EMBEDDING_DIMENSIONS=768

# =============================================================================
# LLM CONFIGURATION (for memory consolidation)
# =============================================================================
# Ollama serves LFM 2.5 1.2B for consolidation (CPU-only inference).
LLM_PROVIDER=ollama
LLM_MODEL=liquid/lfm2.5:1.2b

# =============================================================================
# OPENAI CONFIGURATION (optional — fallback only)
# =============================================================================
# Only required if EMBEDDING_PROVIDER=openai or LLM_PROVIDER=openai.
# Leave blank to use Ollama for everything (recommended for this server).
OPENAI_API_KEY=

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================
MCP_SERVER_NAME=ai-memory-mcp
MCP_SERVER_VERSION=1.0.0
MCP_SERVER_PORT=3000

# Bearer token required on all /mcp requests (leave blank to disable auth).
# [AUTO-GENERATED by deploy-server.sh]
# Generate manually with: openssl rand -hex 32
MCP_AUTH_TOKEN=change-me-or-auto-generated

MCP_LOG_LEVEL=info

# =============================================================================
# DASHBOARD CONFIGURATION
# =============================================================================
# Public URL of the API as seen by the browser (used by Next.js client code).
# This should be the Traefik-routed hostname accessible to your clients.
NEXT_PUBLIC_API_URL=http://api.memory.internal
DASHBOARD_PORT=3000

# =============================================================================
# MEMORY TIERS CONFIGURATION
# =============================================================================
# Tier 1: Project-scoped memory (isolated per project)
# Tier 2: General long-term memory (shared across projects, user-specific)
# Tier 3: Global bootstrap memory (shared across all users)
DEFAULT_MEMORY_TIER=1
MAX_MEMORY_SIZE_MB=100
MEMORY_RETENTION_DAYS=90

# =============================================================================
# MULTI-TENANCY
# =============================================================================
MULTI_TENANCY_ENABLED=true
DEFAULT_TENANT_ID=default

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# SECURITY
# =============================================================================
# JWT signing secret — used for dashboard auth tokens.
# [AUTO-GENERATED by deploy-server.sh]
# Generate manually with: openssl rand -hex 32
JWT_SECRET=change-me-or-auto-generated

# Comma-separated API keys for programmatic access (MCP, direct API).
# [AUTO-GENERATED by deploy-server.sh]
# Generate manually with: openssl rand -hex 24
API_KEYS=change-me-or-auto-generated

# Dashboard admin credentials
ADMIN_USERNAME=admin
# Generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# CORS allowed origins for MCP server
# Use * to allow all Tailscale clients, or restrict to specific hostnames
CORS_ORIGINS=*
