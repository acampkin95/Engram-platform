# AI Memory System Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# WEAVIATE CONFIGURATION
# =============================================================================
WEAVIATE_URL=http://localhost:8080
WEAVIATE_GRPC_URL=http://localhost:50051
WEAVIATE_API_KEY=

# =============================================================================
# REDIS CONFIGURATION  
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =============================================================================
# EMBEDDING CONFIGURATION
# =============================================================================
# Options: openai, cohere, local, ollama
# Standardised to 768d Nomic for consistency with Ollama local embeddings
EMBEDDING_PROVIDER=nomic
OPENAI_API_KEY=
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# =============================================================================
# LLM CONFIGURATION (for memory consolidation)
# =============================================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================
MCP_SERVER_NAME=ai-memory-mcp
MCP_SERVER_VERSION=1.0.0
MCP_SERVER_PORT=3000

# Bearer token required on all /mcp requests (leave blank to disable auth)
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# =============================================================================
# DASHBOARD CONFIGURATION
# =============================================================================
# Public URL of the API (used by browser-side Next.js code)
NEXT_PUBLIC_API_URL=https://memory.velocitydigi.com/api
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_TENANT=default
NEXT_PUBLIC_DEFAULT_PROJECT=default
DASHBOARD_PORT=3001

# =============================================================================
# MEMORY TIERS CONFIGURATION
# =============================================================================
# Tier 1: Project-scoped memory (isolated per project)
# Tier 2: General long-term memory (shared across projects, user-specific)
# Tier 3: Global bootstrap memory (shared across all users)

DEFAULT_MEMORY_TIER=1
MAX_MEMORY_SIZE_MB=100
MEMORY_RETENTION_DAYS=90

# =============================================================================
# MULTI-TENANCY
# =============================================================================
MULTI_TENANCY_ENABLED=true
DEFAULT_TENANT_ID=default

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
MCP_LOG_LEVEL=info

# =============================================================================
# SECURITY
# =============================================================================
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated API keys for programmatic access (MCP, etc.)
# Example: API_KEYS=key1,key2,key3
API_KEYS=
# Used by packages/mcp-server; typically set to one value from API_KEYS
AI_MEMORY_API_KEY=

# Dashboard admin credentials
ADMIN_USERNAME=admin
# Generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# =============================================================================
# DEPLOYMENT
# =============================================================================
# Your production domain
DOMAIN=memory.velocitydigi.com

# Allowed CORS origins (comma-separated). Include all frontend origins.
# Example: CORS_ORIGINS=http://localhost:3001,http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Path to SSL certificates on the host (mapped into nginx container)
# Certbot default: /etc/letsencrypt/live/${DOMAIN}
SSL_CERT_DIR=/etc/letsencrypt/live/memory.velocitydigi.com

# =============================================================================
# MINIO / WEAVIATE OFFLOAD
# =============================================================================
# MinIO / Weaviate offload
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_WEAVIATE_OFFLOAD=weaviate-offload
# Investigation services
MEMORY_API_URL=http://memory-api:8000
INVESTIGATION_CRAWLER_DEPTH=2
INVESTIGATION_CRAWLER_MAX_URLS_PER_MATTER=500
INVESTIGATION_WORKERS_INTERVAL_MINUTES=15
# Ollama — MUST use OLLAMA_HOST (not OLLAMA_BASE_URL)
OLLAMA_HOST=http://ollama:11434

# =============================================================================
# DEEPINFRA CONFIGURATION (cloud inference fallback)
# =============================================================================
# Get your key at: https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=
DEEPINFRA_CHAT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
DEEPINFRA_EMBED_MODEL=BAAI/bge-m3
