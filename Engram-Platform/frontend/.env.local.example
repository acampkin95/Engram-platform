# Local development overrides
# These are only needed when running `npm run dev` outside Docker.
# In Docker/production, nginx handles routing to /api/memory and /api/crawler.

NEXT_PUBLIC_MEMORY_API_URL=http://localhost:8000
NEXT_PUBLIC_CRAWLER_API_URL=http://localhost:11235

# Server-side (used by Next.js API routes, not exposed to browser)
MEMORY_API_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379

# BetterAuth — Authentication
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3002
BETTER_AUTH_DOMAIN=localhost

# Google OAuth (optional — leave blank to disable Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=

# Admin access — comma-separated email addresses for admin panel
# If empty, any authenticated user has admin access (single-user mode)
ENGRAM_ADMIN_EMAILS=

# Default admin account (used by /setup seed route on first boot)
# Leave empty to show setup page on first load
ENGRAM_ADMIN_EMAIL=
ENGRAM_ADMIN_PASSWORD=

# SQLite auth database path
AUTH_DB_PATH=./auth.db
