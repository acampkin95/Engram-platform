# Local development overrides
# These are only needed when running `npm run dev` outside Docker.
# In Docker/production, nginx handles routing to /api/memory and /api/crawler.

NEXT_PUBLIC_MEMORY_API_URL=http://localhost:8000
NEXT_PUBLIC_CRAWLER_API_URL=http://localhost:11235

# Server-side keys (used by Next.js API routes, not exposed to browser)
MEMORY_API_URL=http://localhost:8000
MEMORY_API_KEY=your-admin-api-key-here
MCP_AUTH_TOKEN=your-mcp-auth-token-here
