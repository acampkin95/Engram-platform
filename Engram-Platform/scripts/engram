#!/bin/bash
# =============================================================================
#  Engram Platform — Quick Management Script
#  Simple commands for common operations
# =============================================================================

# Configuration
INSTALL_DIR="${ENGRAM_INSTALL_DIR:-/opt/engram}"
SCRIPT_DIR="${INSTALL_DIR}/scripts"
LOG_DIR="/var/log/engram"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

# Commands
case "${1:-}" in
    start)
        echo -e "${GREEN}Starting Engram Platform...${NC}"
        sudo systemctl start engram-platform
        sudo systemctl start engram-health-monitor
        ;;
    stop)
        echo -e "${YELLOW}Stopping Engram Platform...${NC}"
        sudo systemctl stop engram-health-monitor
        sudo systemctl stop engram-platform
        ;;
    restart)
        echo -e "${BLUE}Restarting Engram Platform...${NC}"
        sudo systemctl restart engram-platform
        ;;
    status)
        echo -e "${BLUE}Engram Platform Status:${NC}"
        echo ""
        sudo systemctl status engram-platform --no-pager
        echo ""
        echo -e "${BLUE}Container Status:${NC}"
        docker compose -f "${INSTALL_DIR}/docker-compose.yml" ps
        ;;
    logs)
        shift
        if [[ -n "${1:-}" ]]; then
            sudo docker compose -f "${INSTALL_DIR}/docker-compose.yml" logs -f --tail=100 "$@"
        else
            sudo docker compose -f "${INSTALL_DIR}/docker-compose.yml" logs -f --tail=100
        fi
        ;;
    health)
        echo -e "${BLUE}Running health check...${NC}"
        bash "${SCRIPT_DIR}/engram-health-monitor.sh" --once 2>/dev/null || \
            curl -fsS http://localhost:8080/health && \
            curl -fsS http://localhost:8000/health && \
            curl -fsS http://localhost:11235/ && \
            echo -e "${GREEN}All endpoints healthy${NC}"
        ;;
    ps)
        docker compose -f "${INSTALL_DIR}/docker-compose.yml" ps
        ;;
    pull)
        echo -e "${CYAN}Pulling latest images...${NC}"
        docker compose -f "${INSTALL_DIR}/docker-compose.yml" pull
        ;;
    update)
        echo -e "${CYAN}Updating and restarting...${NC}"
        docker compose -f "${INSTALL_DIR}/docker-compose.yml" pull
        docker compose -f "${INSTALL_DIR}/docker-compose.yml" up -d --build
        ;;
    clean)
        echo -e "${YELLOW}Cleaning up unused resources...${NC}"
        docker system prune -f --volumes
        ;;
    help|--help|-h)
        echo -e "${BLUE}Engram Platform Management${NC}"
        echo ""
        echo "Usage: $0 <command>"
        echo ""
        echo "Commands:"
        echo "  start     Start all services"
        echo "  stop      Stop all services"
        echo "  restart   Restart all services"
        echo "  status    Show service status"
        echo "  logs      Show logs (optional: service name)"
        echo "  health    Run health check"
        echo "  ps        Show container status"
        echo "  pull      Pull latest images"
        echo "  update    Pull and rebuild"
        echo "  clean     Clean up unused Docker resources"
        echo ""
        ;;
    *)
        exec "$0" help
        ;;
esac
