# ============================================
# Engram Platform — Environment Variables
# ============================================
# Copy to .env and fill in your values.
# Only a few are required — most have sensible defaults.

# ============================================
# REQUIRED — Authentication
# ============================================
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-min-32-chars

# ============================================
# REQUIRED — Embedding Provider
# ============================================
# Options: deepinfra, openai, nomic, ollama
EMBEDDING_PROVIDER=deepinfra
DEEPINFRA_API_KEY=your-deepinfra-key
# OPENAI_API_KEY=sk-...        # Only if EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=              # Override default model per provider
# EMBEDDING_DIMENSIONS=         # Override default dimensions

# ============================================
# Initial Admin (leave empty for setup page)
# ============================================
ENGRAM_ADMIN_EMAIL=
ENGRAM_ADMIN_PASSWORD=
# ENGRAM_ADMIN_EMAILS=          # Comma-separated allowlist (empty = single-user mode)

# ============================================
# Network Binding
# ============================================
# Use 127.0.0.1 for local-only, Tailscale IP for VPN access
BIND_ADDRESS=127.0.0.1
NEXT_PUBLIC_APP_URL=https://memory.velocitydigi.com

# ============================================
# Google OAuth (optional)
# ============================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# ============================================
# Observability (optional)
# ============================================
MCP_LOG_LEVEL=info
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# ============================================
# LM Studio (optional, for crawler AI review)
# ============================================
# LM_STUDIO_URL=http://host.docker.internal:1234

# ============================================
# Notifications (optional)
# ============================================
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=alerts@velocitydigi.com
# NTFY_API_KEY=tk_xxxxxxxxxxxx
# NTFY_TOPIC_URL=https://ntfy.sh/engram-alerts
