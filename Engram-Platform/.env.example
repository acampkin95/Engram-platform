# ============================================
# Engram-Platform Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Clerk Authentication (for AiCrawler)
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ============================================
# Memory API Authentication
# ============================================
NEXT_PUBLIC_MEMORY_API_KEY=your-memory-api-key-here
MEMORY_API_KEY=your-memory-api-key-here

# ============================================
# AiMemory Configuration
# ============================================
JWT_SECRET=your-jwt-secret-min-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$...  # bcrypt hash

# ============================================
# Embedding Provider Configuration
# ============================================
EMBEDDING_PROVIDER=deepinfra
# OPENAI_API_KEY=sk-...  # Only needed if EMBEDDING_PROVIDER=openai
# OPENAI_BASE_URL=
DEEPINFRA_API_KEY=your-deepinfra-key
EMBEDDING_MODEL=BAAI/bge-en-icl
EMBEDDING_DIMENSIONS=1024

# ============================================
# Weaviate Configuration
# ============================================
WEAVIATE_API_KEY=  # leave empty for anonymous access

# ============================================
# LM Studio (for AiCrawler RAG/Chat)
# ============================================
LM_STUDIO_URL=http://host.docker.internal:1234

# ============================================
# Application URLs
# ============================================
# Local: http://localhost:3002
# Tailscale: http://<tailscale-machine-name>:3002
# Production: https://memory.velocitydigi.com
NEXT_PUBLIC_APP_URL=https://memory.velocitydigi.com

# ============================================
# Tailscale / Network Binding
# ============================================
# Bind exposed ports to this address. Use 127.0.0.1 for local-only,
# or your Tailscale IP (e.g. 100.100.42.6) for Tailscale-only access.
# NEVER use 0.0.0.0 in production.
BIND_ADDRESS=127.0.0.1

# Tailscale MagicDNS hostname (for CORS and cert provisioning)
TAILSCALE_HOSTNAME=dv-syd-host01.icefish-discus.ts.net

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins.
# Include: Localhost, Tailscale IPs, and Production Domains
CORS_ORIGINS=https://memory.velocitydigi.com,https://engram.velocitydigi.com,http://localhost:3002,http://localhost:3001,https://dv-syd-host01.icefish-discus.ts.net,https://100.100.42.6

# CORS Configuration
# ============================================
# Comma-separated list of allowed origins.
# Include: Localhost, Tailscale IPs, and Production Domains
CORS_ORIGINS=https://memory.velocitydigi.com,https://engram.velocitydigi.com,http://localhost:3002,http://localhost:3001



# ============================================
# MinIO Configuration (optional, for Weaviate offload)
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_WEAVIATE_OFFLOAD=weaviate-offload

# ============================================
# Ollama Configuration (optional, for AiMemory maintenance)
# ============================================
OLLAMA_HOST=http://host.docker.internal:11434

# ============================================
# MCP Server Configuration
# ============================================
MCP_AUTH_TOKEN=your-mcp-auth-token-here
# MCP Server Configuration
# ============================================
MCP_AUTH_TOKEN=your-mcp-auth-token-here
CORS_ORIGINS=http://localhost:3002,http://localhost:3001

# ============================================
# Crawler Configuration
# ============================================
ENGRAM_ENABLED=true
ENGRAM_API_URL=http://memory-api:8000
ENGRAM_AUTO_STORE=true
ENGRAM_API_KEY=  # optional, leave empty if no auth

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://crawler-redis:6379/0
MEMORY_REDIS_URL=redis://memory-redis:6379

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
