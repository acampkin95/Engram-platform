# --- Secrets & Environment ---
.env
.env.production
.env.local
.env.*.local
*.key
*.pem
*.crt
*.p12
*.pfx
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc

# --- Virtual environments ---
.venv/
venv/
ENV/
env/
.env/

# --- Testing ---
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
htmlcov/

# --- Data directories (runtime data, not source) ---
data/
*.db
*.sqlite
*.sqlite3

# --- Logs ---
logs/
*.log
*.log.*

# --- Docker volumes & runtime ---
.docker/
docker-volumes/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Node (frontend) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
frontend/dist/
frontend/build/
frontend/playwright-report/
frontend/test-results/
.next/
.nuxt/

# --- Certificates (runtime, managed by certbot) ---
nginx/ssl/
certbot/

# --- Backup artifacts ---
*.tar.gz
*.tar.bz2
*.zip
backups/

# --- Jupyter ---
.ipynb_checkpoints
*.ipynb

# --- MyPy ---
.mypy_cache/
.dmypy.json
dmypy.json

# --- Ruff / Pylint ---
.ruff_cache/

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/

# --- AI Tool State (not source) ---
.omc/
.sisyphus/
.claude/
.aistore/
