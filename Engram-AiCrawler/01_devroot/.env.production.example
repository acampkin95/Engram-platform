# =============================================================================
# OSINT Investigation Platform — Production Environment Template
# =============================================================================
# Copy this file to .env.production and fill in real values.
# This file is SAFE to commit — it contains no secrets.
# =============================================================================

# --- Application ---
APP_ENV=production
APP_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=11235
LOG_LEVEL=INFO

# --- Domain (required for nginx SSL config) ---
DOMAIN=your-domain.com

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- API Keys (fill in as required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
SERP_API_KEY=

# --- Tor (internal Docker service names) ---
TOR_SOCKS_HOST=tor
TOR_SOCKS_PORT=9050
TOR_CONTROL_HOST=tor
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=

# --- StorJ S3 Backup (via rclone env-var config) ---
RCLONE_CONFIG_STORJ_TYPE=s3
RCLONE_CONFIG_STORJ_PROVIDER=Other
RCLONE_CONFIG_STORJ_ACCESS_KEY_ID=YOUR_STORJ_ACCESS_KEY
RCLONE_CONFIG_STORJ_SECRET_ACCESS_KEY=YOUR_STORJ_SECRET_KEY
RCLONE_CONFIG_STORJ_ENDPOINT=https://gateway.storjshare.io
RCLONE_CONFIG_STORJ_ACL=private
STORJ_BUCKET=osint-investigation-backups
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=30

# --- ChromaDB ---
CHROMA_PERSIST_DIR=/app/data/chroma

# --- Case Storage ---
CASES_DIR=/app/data/cases
FACE_REFS_DIR=/app/data/face_refs

# --- Storage tiers ---
HOT_STORAGE_DIR=/app/data/hot
WARM_STORAGE_DIR=/app/data/warm
COLD_STORAGE_DIR=/app/data/cold
ARCHIVE_DIR=/app/data/archive

# --- Rate limiting ---
MAX_CONCURRENT_CRAWLS=5
RATE_LIMIT_PER_MINUTE=30
