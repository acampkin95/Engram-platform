# Application Settings
APP_NAME=crawl4ai-osint
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=11235
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Crawl4AI Configuration
CRAWL4AI_VERSION=0.7.8
BROWSER_TYPE=chromium
HEADLESS=true
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
CACHE_ENABLED=true
CACHE_MODE=enabled
WORD_COUNT_THRESHOLD=50
SEMOPHORE_COUNT=5
PAGE_TIMEOUT=30000

# LM Studio Configuration
LM_STUDIO_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_TIMEOUT=60
LM_STUDIO_MAX_RETRIES=3
LM_STUDIO_RETRY_DELAY=5
LM_STUDIO_TEMPERATURE=0.7

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ChromaDB Configuration
CHROMADB_PATH=/app/data/chroma
CHROMADB_COLLECTION_PREFIX=scan_
CHROMADB_SIMILARITY_THRESHOLD=0.75
CHROMADB_EMBEDDING_BATCH_SIZE=32

# Data Lifecycle
DATA_HOT_PATH=/app/data/tiers/hot
DATA_WARM_PATH=/app/data/tiers/warm
DATA_COLD_PATH=/app/data/tiers/cold
DATA_ARCHIVE_PATH=/app/data/tiers/archive
DATA_HOT_MAX_AGE_HOURS=24
DATA_WARM_MAX_AGE_DAYS=3
DATA_COLD_MAX_AGE_DAYS=7
DATA_OFFLOAD_THRESHOLD_DAYS=3
DATA_ARCHIVE_THRESHOLD_GB=50
DATA_CLEANUP_INTERVAL_MINUTES=5

# Watchdog Configuration
WATCHDOG_CHECK_INTERVAL_SECONDS=30
WATCHDOG_ORPHAN_AGE_MINUTES=60
WATCHDOG_MEMORY_THRESHOLD_PERCENT=90
WATCHDOG_DISK_THRESHOLD_PERCENT=85
WATCHDOG_MEMORY_CHECK_ENABLED=true
WATCHDOG_DISK_CHECK_ENABLED=true

# OSINT Configuration
OSINT_PLATFORMS=twitter,linkedin,instagram,facebook,reddit,tiktok
OSINT_STEALTH_MODE=true
OSINT_USER_AGENT_ROTATION=true
OSINT_RATE_LIMIT_ENABLED=true
OSINT_PARALLEL_CRAWLS=10
OSINT_IMAGE_SIMILARITY_THRESHOLD=0.85
OSINT_SEARCH_QUERIES_PER_PLATFORM=10

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
USER_REQUESTS_PER_MINUTE=60
ADMIN_REQUESTS_PER_MINUTE=120
USER_DAILY_QUOTA=1000
ADMIN_DAILY_QUOTA=10000

# Authentication Configuration (Clerk JWT)
# Set AUTH_ENABLED to true to enable authentication
AUTH_ENABLED=false
# Protect routes (POST/PUT/DELETE) - requires AUTH_ENABLED=true
PROTECTED_ROUTES_ENABLED=false
# Clerk credentials - get from Clerk Dashboard > API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_KEY=pk_test_...
CLERK_ISSUER=https://your-clerk-domain.clerk.com
CLERK_AUDIENCE=your-application-identifier
# Comma-separated list of admin email addresses
CLERK_ADMIN_USERS=admin@example.com
# Token configuration
TOKEN_EXPIRY_HOURS=24
REFRESH_BUFFER_MINUTES=30

# Cache Configuration
CACHE_ENABLED=true
CACHE_BACKEND=redis
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=1000

# Performance Configuration
PERFORMANCE_MAX_CONCURRENT_CRAWLS=10
PERFORMANCE_REQUEST_TIMEOUT=30
PERFORMANCE_CHUNK_SIZE=1024
PERFORMANCE_OVERLAP_RATE=0.1

# OpenAI API Key (optional, for external LLM providers)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# Proxy Configuration (optional)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Engram Memory Integration (optional — run `c4ai setup` to configure interactively)
# Set ENGRAM_ENABLED=true to persist crawl results in the Weaviate-based Engram memory system.
# ENGRAM_ENABLED=false
# ENGRAM_API_URL=http://localhost:8000
# ENGRAM_API_KEY=
# ENGRAM_AUTO_STORE=true
