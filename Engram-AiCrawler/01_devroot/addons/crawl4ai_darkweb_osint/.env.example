# Crawl4AI Dark Web OSINT Addon - Environment Configuration
# Copy to your project root and customize

# Tor Configuration
DARKWEB_TOR_PROXY_HOST=127.0.0.1
DARKWEB_TOR_PROXY_PORT=9050

# LLM Configuration
DARKWEB_LLM_PROVIDER=lmstudio
DARKWEB_LLM_MODEL=glm-5
DARKWEB_LLM_BASE_URL=http://localhost:1234/v1
DARKWEB_LLM_API_KEY=your-api-key-here

# Optional: Override addon path
# DARKWEB_ADDON_PATH=/path/to/addon
