{
	"name": "engram-mcp",
	"version": "1.2.0",
	"description": "Engram MCP Server — AI memory persistence via Model Context Protocol. Dual transport (stdio + HTTP streaming), OAuth 2.1, automatic memory hooks, and guided installer for any MCP-compatible client.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": {
		"engram-mcp": "./dist/index.js",
		"engram-mcp-init": "./dist/installer/cli.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/index.js",
		"start:stdio": "node dist/index.js --transport stdio",
		"start:http": "node dist/index.js --transport http",
		"install-mcp": "node dist/installer/cli.js",
		"smoke": "npm run build && node scripts/smoke.mjs",
		"test": "npm run build && node --test tests/*.test.ts",
		"test:coverage": "npm run build && node --experimental-test-coverage --test tests/*.test.ts",
		"lint": "biome check .",
		"format": "biome format . --write"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.7",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"hono": "^4.7.5",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^20.0.0",
		"c8": "^11.0.0",
		"typescript": "^5.6.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"files": [
		"dist",
		"hookify",
		"templates",
		"install.sh",
		"README.md"
	],
	"keywords": [
		"mcp",
		"model-context-protocol",
		"ai-memory",
		"engram",
		"oauth",
		"hookify",
		"memory",
		"knowledge-graph",
		"vector-search",
		"rag"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/acampkin/engram-mcp.git"
	},
	"homepage": "https://github.com/acampkin/engram-mcp#readme",
	"bugs": {
		"url": "https://github.com/acampkin/engram-mcp/issues"
	}
}
