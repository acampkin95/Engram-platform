# =============================================================================
# Engram Unified MCP Server — Environment Configuration
# =============================================================================

# --- Transport ---
# Which transport to use: "http" (default) or "stdio"
MCP_TRANSPORT=http

# --- HTTP Transport ---
MCP_SERVER_PORT=3000
MCP_SERVER_NAME=engram-mcp
MCP_SERVER_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# --- Memory API Backend ---
MEMORY_API_URL=http://localhost:8000
AI_MEMORY_API_KEY=your-api-key-here

# --- Authentication ---
# Simple Bearer token auth (backward compat, used when OAuth is disabled)
MCP_AUTH_TOKEN=your-bearer-token-here

# --- OAuth 2.1 (HTTP transport only) ---
OAUTH_ENABLED=false
OAUTH_ISSUER=http://localhost:3000
OAUTH_SECRET=change-this-to-a-random-secret-at-least-32-chars
OAUTH_ACCESS_TOKEN_TTL=3600
OAUTH_REFRESH_TOKEN_TTL=86400
OAUTH_REDIS_URL=
OAUTH_REDIS_KEY_PREFIX=mcp:oauth:

# --- Resilience ---
MCP_RETRY_MAX=3
MCP_RETRY_INITIAL_MS=100
MCP_RETRY_MAX_MS=5000
MCP_RETRY_BACKOFF=2
MCP_RETRY_JITTER=0.1
MCP_CB_FAILURE_THRESHOLD=5
MCP_CB_RESET_MS=30000
MCP_CB_SUCCESS_THRESHOLD=2
MCP_CB_WINDOW_MS=60000

# --- Logging ---
MCP_LOG_LEVEL=info
MCP_LOG_TIMESTAMPS=true
MCP_LOG_REQUEST_IDS=true
MCP_LOG_STDERR=true

# --- Timeouts ---
MCP_TIMEOUT_MS=30000
MCP_CONNECT_TIMEOUT_MS=5000
MCP_READ_TIMEOUT_MS=30000
